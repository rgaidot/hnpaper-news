{
  "name": "hnpaper-news-rust",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i ./styles/input.css -o ./static/css/global.css --minify",
    "build:js": "esbuild client/main.ts --bundle --outfile=static/js/main.js --minify --target=es2020",
    "build": "bun run build:css && bun run build:js && zola build",
    "dev": "bun run build:css && bun run build:js && zola serve"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "tailwindcss": "^3.4.1",
    "@tailwindcss/typography": "^0.5.10"
  }
}
