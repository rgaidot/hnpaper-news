    "astro": "^5.16.15",
    "date-fns": "^4.1.0",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@vite-pwa/astro": "^1.2.0",
    "front-matter": "^4.0.2",
    "glob": "^13.0.6",
    "ora": "^9.3.0",
    "pagefind": "^1.4.0",
    "workbox-window": "^7.4.0"
