---
import { slugify } from "../utils/slugify";

interface Props {
  tags: string[] | undefined;
  centered?: boolean;
}

const { tags, centered = false } = Astro.props;
---

{tags && tags.length > 0 && (
  <div class={`flex flex-wrap gap-2 ${centered ? 'justify-center' : ''}`}>
    {tags.map(tag => (
      <a 
        href={`/tags/${slugify(tag)}`}
        class="px-2 py-0.5 border border-stone-200 rounded-full text-[10px] text-stone-500 font-sans font-bold uppercase tracking-wider bg-stone-50/50 hover:bg-stone-200 hover:text-stone-900 transition-colors"
      >
        {tag}
      </a>
    ))}
  </div>
)}
