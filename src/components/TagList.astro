---
import { slugify } from "../utils/slugify";

interface Props {
  tags: string[] | undefined;
  centered?: boolean;
}

const { tags, centered = false } = Astro.props;
---

{tags && tags.length > 0 && (
  <div class={`flex flex-wrap gap-2 ${centered ? 'justify-center' : ''} relative z-10`}>
    {tags.map(tag => (
      <a 
        href={`/tags/${slugify(tag)}`}
        class="px-2.5 py-1 border border-stone-300 rounded-full text-[10px] text-stone-600 font-sans font-bold uppercase tracking-widest bg-stone-100 hover:bg-stone-900 hover:text-white transition-colors"
      >
        {tag}
      </a>
    ))}
  </div>
)}
