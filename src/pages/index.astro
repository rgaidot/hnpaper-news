---
import { getCollection } from "astro:content";
import TTSPlayer from "../components/TTSPlayer.astro";
import AudioPlayer from "../components/AudioPlayer.astro";
import TagList from "../components/TagList.astro";
import Layout from "../layouts/Layout.astro";
import { formatFrenchDate } from "../utils/formatDate";
import { getReadingTimeMinutes } from "../utils/readingTime";
import { hasAudio } from "../utils/audio";
import { getLatestNews, sortNewsByDateDesc } from "../utils/news";

const allNews = await getCollection("news");
const sortedNews = sortNewsByDateDesc(allNews);
const latestPost = getLatestNews(sortedNews);

let Content, formattedDate, readingTime, audioFileExists;

if (latestPost) {
  const rendered = await latestPost.render();
  Content = rendered.Content;

  formattedDate = formatFrenchDate(latestPost.data.date);

  readingTime = getReadingTimeMinutes(latestPost.body);

  audioFileExists = hasAudio(latestPost.slug);
}
---

<Layout title="The HNPaper Daily">
  {
    latestPost ? (
      <>
        <article class="mx-auto max-w-5xl">
          <header
            class="mb-10 text-center"
          >
            <div
              class="flex flex-col items-center space-y-2 text-stone-600 font-serif text-sm uppercase tracking-widest pb-8"
            >
              <span class="text-2xl font-bold font-serif text-stone-600 uppercase tracking-wides" data-pagefind-meta="title">{formattedDate}</span>
              <TagList tags={latestPost.data.tags} centered={true} />
            </div>
            <div class="border-t-4 border-b-4 border-double border-stone-300">
              <TTSPlayer
                title={latestPost.data.title}
                readingTime={readingTime}
                slug={latestPost.slug}
              />
            </div>
          </header>
          <div class="prose prose-stone prose-lg max-w-none mx-auto text-justify masonry-grid prose-headings:font-serif prose-headings:font-bold prose-headings:text-stone-900 prose-p:font-serif prose-p:text-stone-800 prose-a:text-stone-900 prose-a:underline prose-a:decoration-1 hover:prose-a:decoration-2 prose-a:font-normal prose-strong:text-base prose-blockquote:border-l-2 prose-blockquote:border-stone-900 prose-blockquote:pl-4 prose-blockquote:italic prose-blockquote:text-stone-700 prose-img:border prose-img:border-stone-900 prose-img:p-1">
            <Content />
          </div>

          <script>
            import { initMasonrySections } from "../scripts/client/masonry";

            initMasonrySections();
          </script>
        </article>
      </>
    ) : (
      <div class="text-center py-20">
        <p>Aucune actualité disponible pour le moment.</p>
      </div>
    )
  }
  {latestPost && audioFileExists && <AudioPlayer title={latestPost.data.title} slug={latestPost.slug} formattedDate={formattedDate} />}
</Layout>
