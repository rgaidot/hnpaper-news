---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import TagList from '../../components/TagList.astro';
import { formatFrenchDateShort } from '../../utils/formatDate';
import { formatReadingTimeMinutes, getReadingTimeMinutes } from '../../utils/readingTime';
import { sortNewsByDateDesc } from '../../utils/news';

export async function getStaticPaths({ paginate }) {
  const allNews = await getCollection('news');
  const sortedNews = sortNewsByDateDesc(allNews);
  return paginate(sortedNews, { pageSize: 12 });
}

const { page } = Astro.props;
---

<Layout title={`Archives - Page ${page.currentPage}`}>
  <div class="mb-12 border-b-4 border-double border-stone-300 pb-4 text-center">
    <h2
      class="text-2xl font-bold font-serif text-stone-600 uppercase tracking-widest"
    >
      Archives
    </h2>
    <span
      class="text-xs font-sans font-bold uppercase tracking-widest text-stone-500 mt-2 block"
      >Page {page.currentPage} sur {page.lastPage}</span
    >
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
    {
      page.data.map((post) => (
        <article class="break-inside-avoid w-full flex flex-col bg-white p-6 md:p-8 rounded-[1rem] shadow-sm border border-stone-200/80 hover:shadow-md hover:border-stone-300 transition-all text-left">
          <div class="mb-4 text-xs font-bold tracking-widest text-stone-500 uppercase border-b border-stone-100 pb-2 flex justify-between w-full">
            <span>
              {formatFrenchDateShort(post.data.date)}
            </span>
            <span>{formatReadingTimeMinutes(getReadingTimeMinutes(post.body || ""))}</span>
          </div>

          <div class="mb-4">
            <TagList tags={post.data.tags} />
          </div>

          <p class="text-stone-700 font-serif text-base lg:text-lg leading-relaxed mb-6 flex-grow line-clamp-6 text-justify">
            {(post.body || "").split("---")[0]?.replace(/^#+\s/, "")}
          </p>

          <ul class="mt-auto pt-6 border-t border-stone-100 text-sm font-sans font-bold tracking-wider text-stone-500 !mb-0 list-none pl-0">
            <li>
              <a
                href={`/archives/${post.id}`}
                class="text-stone-900 underline decoration-1 underline-offset-4 hover:decoration-2 transition-all font-medium"
              >
                Lire <span aria-hidden="true">&rarr;</span>
              </a>
            </li>
          </ul>
        </article>
      ))
    }
  </div>

  <nav
    class="flex justify-center items-center space-x-4 mt-16 font-serif pt-8 border-t border-stone-300"
  >
    {
      page.url.prev ? (
        <a
          href={page.url.prev}
          class="px-6 py-2 border border-stone-900 text-stone-900 font-bold hover:bg-stone-900 hover:text-white transition-colors uppercase text-sm tracking-widest"
        >
          &larr; Précédent
        </a>
      ) : (
        <span class="px-6 py-2 border border-stone-200 text-stone-300 uppercase text-sm tracking-widest cursor-not-allowed">
          &larr; Précédent
        </span>
      )
    }

    <div class="hidden sm:flex px-4 font-bold text-stone-900">
      Page {page.currentPage}
    </div>

    {
      page.url.next ? (
        <a
          href={page.url.next}
          class="px-6 py-2 border border-stone-900 text-stone-900 font-bold hover:bg-stone-900 hover:text-white transition-colors uppercase text-sm tracking-widest"
        >
          Suivant &rarr;
        </a>
      ) : (
        <span class="px-6 py-2 border border-stone-200 text-stone-300 uppercase text-sm tracking-widest cursor-not-allowed">
          Suivant &rarr;
        </span>
      )
    }
  </nav>
</Layout>
